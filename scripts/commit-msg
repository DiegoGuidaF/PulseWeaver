#!/usr/bin/env bash
# Validates that commit messages follow the Conventional Commits spec.
# Install: make install-hooks

MSG_FILE="$1"
FIRST_LINE=$(head -n1 "$MSG_FILE")


# Pattern: type[(scope)][[PW-N]][!]: description
PATTERN='^(build|chore|ci|docs|feat|fix|refactor|revert|style|test)(\([a-z0-9,/-]+\))?(\[PW-[0-9]+\])?!?: .{1,}'

if ! [[ "$FIRST_LINE" =~ $PATTERN ]]; then
  echo ""
  echo "❌ Invalid commit message format."
  echo ""
  echo "   Expected: <type>[(scope)][[PW-N]]: <description>"
  echo "   Example:  feat(ui): add dashboard chart"
  echo "   Example:  feat(ui)[PW-42]: add dashboard chart"
  echo "   Example:  fix: handle nil pointer in auth handler"
  echo "   Example:  feat!: redesign API (breaking change)"
  echo ""
  echo "   Types: build, chore, ci, docs, feat, fix, perf, refactor, style, test"
  echo "   Scopes are optional. Omit scope for cross-cutting changes."
  echo "   Story ID [PW-N] is optional, placed after scope and before colon."
  echo ""
  exit 1
fi

exit 0

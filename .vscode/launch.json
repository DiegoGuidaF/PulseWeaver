{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Launch (Debug)",
      "type": "go",
      "request": "launch",
      "mode": "auto",
      "program": "${workspaceFolder}/cmd/api",
      "envFile": "${workspaceFolder}/.env",
      "args": [],
      "showLog": true,
      "trace": "log"
    },
    {
      "name": "Launch (No Debug)",
      "type": "go",
      "request": "launch",
      "mode": "auto",
      "program": "${workspaceFolder}/cmd/api",
      "envFile": "${workspaceFolder}/.env",
      "args": [],
      "noDebug": true
    },
    {
      "name": "Debug Scratch File",
      "type": "go",
      "request": "launch",
      "mode": "auto",
      "program": "${workspaceFolder}/scratch_test.go",
      "showLog": true
    },
    {
      "name": "Attach to Process",
      "type": "go",
      "request": "attach",
      "mode": "local",
      "processId": 0
    }
  ]
}

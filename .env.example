# Required
ADMIN_PASSWORD="mypasswordisvalid"
POLICY_ENGINE_API_SECRET=thisisasecretvaluesds

# Others
TZ=Europe/Madrid
SERVER_PORT=8080
TRUSTED_PROXY="::1"

# Logging
LOG_LEVEL=debug
LOG_FORMAT=text
LOG_COLOR=TRUE

# Database
DB_DIR=./data

# Data retention (set to 0 to disable)
DATA_RETENTION_DAYS=30
# Hourly traffic aggregates serve dashboard windows wider than 24h;
# must be 0 (unbounded) or >= DATA_RETENTION_DAYS
AGGREGATE_RETENTION_DAYS=365

# Required
ADMIN_PASSWORD="mypasswordisvalid"
POLICY_ENGINE_API_SECRET=thisisasecretvaluesds

# Others
TZ=Europe/Madrid
SERVER_PORT=8080
TRUSTED_PROXY="::1"

# Logging
LOG_LEVEL=debug
LOG_FORMAT=text
LOG_COLOR=TRUE

# Database
DB_DIR=./data

# Data retention (set to 0 to disable)
DATA_RETENTION_DAYS=30
# Hourly traffic aggregates serve dashboard windows wider than 24h;
# must be 0 (unbounded) or >= DATA_RETENTION_DAYS
AGGREGATE_RETENTION_DAYS=365

# Anomaly detection (background scan over the access log + traffic aggregates)
ANOMALY_DETECTION_ENABLED=true
# Scan cadence; self-gated inside the job (scheduler still ticks at RULE_CHECK_INTERVAL)
ANOMALY_SCAN_INTERVAL=5m
# Sensitivity preset for the volume family: low | medium | high
ANOMALY_SENSITIVITY=medium
# Novelty detectors stay silent for a device until its profile is at least this old
ANOMALY_LEARNING_DAYS=7
# Per-family toggles (per-kind granularity waits for a settings UI)
ANOMALY_DETECT_RULES=true
ANOMALY_DETECT_VOLUME=true
ANOMALY_DETECT_NOVELTY=true
# Whether impossible_travel also flags same-continent country hops (noisiest signal, off by default)
ANOMALY_TRAVEL_SAME_CONTINENT=false
